# 文件说明：
# - 本文件是环境变量模板，帮助新手知道项目运行需要哪些配置。
# - 真实密钥请写入本地 .env，不要提交到 Git。
# - 本仓库默认按严格生产 Runtime 启动：缺少后端、模型或受治理知识库时应停止，而不是降级。

# Runtime
APP_ENV=prod

# PostgreSQL / Redis
DATABASE_URL=postgresql+psycopg://agent:agent@localhost:5432/agent_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
REDIS_URL=redis://localhost:6379/0
# Sentinel 模式与 REDIS_URL 二选一：启用时把 REDIS_URL 留空，并填写 Master 名与节点列表。
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_NODES=
# REDIS_PASSWORD 是实际 Master 的密码；Sentinel 自身另有密码时填写 REDIS_SENTINEL_PASSWORD。
REDIS_PASSWORD=
REDIS_SENTINEL_PASSWORD=
REDIS_DATABASE=0
# 业务记忆字段加密密钥；生产请使用 Secret Manager 注入足够强的随机值。
MEMORY_ENCRYPTION_KEY=

# Agent Gateway
AGENT_API_KEY=change-me
# 生产建议使用租户绑定密钥；JSON 应由 Secret Manager 注入，不提交真实值。
# 用 source .env 加载时 JSON 必须整体加单引号，避免 shell 去掉 JSON 的双引号。
AGENT_TENANT_API_KEYS='{"local":"123456"}'
# 本机管理台可显式复用上述租户凭据；严格环境默认关闭，且服务端仍只对回环地址注入。
REGISTRY_CONSOLE_DEFAULTS_ENABLED=false
REGISTRY_CONSOLE_TENANT_ID=
# Registry 管理 API 需要网关租户凭据之外的第二把管理凭据；请由 Secret Manager 注入。
REGISTRY_ADMIN_TOKEN=
REGISTRY_CONSOLE_ACTOR_ID=local-admin
REGISTRY_CONSOLE_ACTOR_ROLES=administrator
# 限流窗口、预算和 Key TTL 统一填写在 configs/api.yaml，避免环境变量与 YAML 双重来源漂移。

# OpenAI-compatible model providers
LLM_BASE_URL=
LLM_API_KEY=
# 若企业模型网关使用 OPENAI_BASE_URL/OPENAI_API_KEY，也可只填写这两个别名；非空 LLM_* 优先。
OPENAI_BASE_URL=
OPENAI_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
# 可使用本地 CrossEncoder，也可配置兼容 /rerank 协议的外部服务，例如 https://dapi.aivue.cn/v1。
RERANKER_BASE_URL=http://127.0.0.1:8002
RERANKER_API_KEY=

# Model names are injected into configs/models.yaml.
DEFAULT_CHAT_MODEL=
FAST_REASONING_MODEL=
MEMORY_RECALL_DECISION_MODEL=
QUERY_UNDERSTANDING_MODEL=
INTENT_CLASSIFIER_MODEL=
# 活跃保险意图续接/换题判断使用的小模型。
INTENT_SHIFT_MODEL=
# 保险领域 KYC 本轮事实抽取模型。
INSURANCE_KYC_EXTRACTOR_MODEL=
GUARDRAIL_MODEL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=3072
# 模型名必须以当前 Reranker 服务实际开通的模型为准；外部免费通道示例为 bge-reranker-v2-m3-free。
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# 可填 Hugging Face 模型 ID，也可改为已离线下载的本地模型绝对路径。
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
LOCAL_RERANKER_API_KEY=
LOCAL_RERANKER_DEVICE=cpu
LOCAL_RERANKER_MAX_DOCUMENTS=50
LOCAL_RERANKER_BATCH_SIZE=8

# External tool providers
WEATHER_API_URL=
WEB_SEARCH_API_URL=
NEWS_SEARCH_API_URL=
WEB_PAGE_READER_API_URL=
FILE_PARSER_API_URL=
KNOWLEDGE_SEARCH_API_URL=
TRANSLATION_API_URL=

# LangSmith optional tracing/evaluation
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insurance-advisor-agent-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=
LANGSMITH_SAMPLING_RATE=1.0
LANGSMITH_FLUSH_TIMEOUT_SECONDS=5
# control_plane_only 仅上传流程摘要；full_business_content 上传业务正文，但两种模式都强制清除凭据。
LANGSMITH_DATA_POLICY=control_plane_only
# 完整模式的单字符串和单集合体积上限，超出时会写入明确截断标记。
LANGSMITH_MAX_FIELD_CHARS=50000
LANGSMITH_MAX_COLLECTION_ITEMS=500
# true 时按业务 Session 聚合 Threads/Turns；每个 Turn 仍可打开完整 Trace Waterfall。
LANGSMITH_THREAD_GROUPING=true

# DeepEval 只在 eval optional extra 和 --enable-deepeval 下启用。
# Runner 会强制关闭 DeepEval 自行加载 dotenv、匿名遥测和 Confident AI 指标上传。
DEEPEVAL_DISABLE_DOTENV=1
DEEPEVAL_TELEMETRY_OPT_OUT=1

# Dify
DIFY_BASE_URL=
DIFY_API_KEY=
# Dify Dataset API 与 Dify App/Workflow API 分开配置；每个逻辑知识库使用独立 Dataset Key。
DIFY_DATASET_BASE_URL=
DIFY_INTENT_DATASET_ID=
DIFY_INTENT_DATASET_API_KEY=
DIFY_METHODS_DATASET_ID=
DIFY_METHODS_DATASET_API_KEY=
DIFY_COMPLIANCE_DATASET_ID=
DIFY_COMPLIANCE_DATASET_API_KEY=
