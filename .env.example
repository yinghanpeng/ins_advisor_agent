# 文件说明：
# - 本文件是环境变量模板，帮助新手知道项目运行需要哪些配置。
# - 真实密钥请写入本地 .env，不要提交到 Git。
# - 当前本地 demo 不依赖外部 API；接入模型、Dify、LangSmith 时再填写对应变量。

# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL / Redis
DATABASE_URL=postgresql+psycopg://agent:agent@localhost:5432/agent_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
REDIS_URL=redis://localhost:6379/0

# Agent Gateway
AGENT_API_KEY=change-me
DEFAULT_TENANT_ID=local
RATE_LIMIT_PER_MINUTE=60

# OpenAI-compatible model providers
LLM_BASE_URL=
LLM_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
RERANKER_BASE_URL=
RERANKER_API_KEY=

# Model names are injected into configs/models.yaml.
DEFAULT_CHAT_MODEL=
FAST_REASONING_MODEL=
MEMORY_RECALL_DECISION_MODEL=
QUERY_UNDERSTANDING_MODEL=
GUARDRAIL_MODEL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=3072
RERANKER_MODEL=

# External tool providers
WEATHER_API_URL=
WEB_SEARCH_API_URL=
NEWS_SEARCH_API_URL=
WEB_PAGE_READER_API_URL=
FILE_PARSER_API_URL=
KNOWLEDGE_SEARCH_API_URL=
TRANSLATION_API_URL=

# LangSmith optional tracing/evaluation
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insurance-advisor-agent-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Cost control
DAILY_TOKEN_BUDGET=200000
REQUEST_TOKEN_BUDGET=12000

# Dify
DIFY_BASE_URL=
DIFY_API_KEY=
