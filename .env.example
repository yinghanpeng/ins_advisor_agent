# 文件说明：
# - 本文件是环境变量模板，帮助新手知道项目运行需要哪些配置。
# - 真实密钥请写入本地 .env，不要提交到 Git。
# - 当前本地 demo 不依赖外部 API；接入模型、Dify、LangSmith 时再填写对应变量。

# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# Agent Gateway
AGENT_API_KEY=change-me
DEFAULT_TENANT_ID=local
RATE_LIMIT_PER_MINUTE=60

# Model Provider
LLM_PROVIDER=openai-compatible
LLM_MODEL=qwen3.5-max
LLM_TIMEOUT_SECONDS=30

# LangSmith optional tracing/evaluation
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insurance-advisor-agent-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Cost control
DAILY_TOKEN_BUDGET=200000
REQUEST_TOKEN_BUDGET=12000

# Dify
DIFY_BASE_URL=
DIFY_API_KEY=
